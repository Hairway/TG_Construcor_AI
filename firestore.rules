rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidPuzzle(data) {
      return data.name is string && 
             data.gridWidth is number && 
             data.gridHeight is number &&
             data.tiles is map &&
             data.previewUrl is string;
    }

    match /puzzles/{puzzleId} {
      allow read: if true;
      allow create: if isValidPuzzle(request.resource.data);
      allow update: if isValidPuzzle(request.resource.data);
      allow delete: if true; // Demo mode: anyone can delete
    }
  }
}
